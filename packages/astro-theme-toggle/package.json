{
  "name": "@sjohansson/astro-theme-toggle",
  "version": "0.0.1",
  "description": "Modern theme toggle component for Astro with Tailwind CSS 4 support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest"
  },
  "keywords": [
    "astro",
    "astro-component",
    "theme",
    "dark-mode",
    "light-mode",
    "tailwindcss"
  ],
  "author": "sjohansson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sjohansson/astro-components.git",
    "directory": "packages/astro-theme-toggle"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "astro": "^5.0.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "sideEffects": ["./dist/**/*.css", "./src/**/*.astro"],
  "devDependencies": {
    "tailwindcss": "^4.0.0"
  }
}
