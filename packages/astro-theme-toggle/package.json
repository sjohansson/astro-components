{
  "name": "@sjohansson/astro-theme-toggle",
  "version": "0.1.1",
  "description": "Framework-agnostic theme toggle with Web Components, optional Astro wrappers",
  "type": "module",
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./astro": {
      "types": "./dist/astro/index.d.ts",
      "import": "./dist/astro/index.js"
    },
    "./integration": {
      "types": "./dist/astro/integration.d.ts",
      "import": "./dist/astro/integration.js"
    },
    "./themes": {
      "types": "./dist/themes/index.d.ts",
      "import": "./dist/themes/index.js"
    },
    "./themes/*": {
      "types": "./dist/themes/*.d.ts",
      "import": "./dist/themes/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "test": "vitest"
  },
  "keywords": [
    "theme",
    "dark-mode",
    "light-mode",
    "web-components",
    "astro",
    "astro-component",
    "accessibility",
    "color-blind"
  ],
  "author": "sjohansson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sjohansson/astro-components.git",
    "directory": "packages/astro-theme-toggle"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "astro": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "astro": {
      "optional": true
    }
  },
  "sideEffects": false
}
