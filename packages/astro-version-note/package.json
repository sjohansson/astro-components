{
  "name": "@sjohansson/astro-version-note",
  "version": "0.1.0",
  "description": "Version note component for Astro sites. Shows the current version of the site in case you want to make sure it is running what you think.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./integration": {
      "types": "./dist/integration.d.ts",
      "import": "./dist/integration.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest"
  },
  "keywords": [
    "astro",
    "astro-component",
    "version",
    "documentation",
    "notes"
  ],
  "author": "sjohansson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sjohansson/astro-components.git",
    "directory": "packages/astro-version-note"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "astro": "^6.0.0"
  },
  "sideEffects": false
}
