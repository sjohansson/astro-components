{
  "name": "@sjohansson/astro-reactflow",
  "version": "0.0.1",
  "description": "React Flow integration for Astro",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./integration": {
      "types": "./dist/integration.d.ts",
      "import": "./dist/integration.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest"
  },
  "keywords": ["astro", "astro-component", "reactflow", "diagrams", "flowchart"],
  "author": "sjohansson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sjohansson/astro-components.git",
    "directory": "packages/astro-reactflow"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "astro": "^5.0.0",
    "@xyflow/react": "^12.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "sideEffects": ["./dist/**/*.css", "./src/**/*.css"],
  "devDependencies": {
    "@xyflow/react": "^12.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5"
  }
}
