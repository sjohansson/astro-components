{
  "name": "@sjohansson/astro-reactflow",
  "version": "0.2.0",
  "description": "React Flow integration for Astro sites",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./integration": {
      "types": "./dist/integration.d.ts",
      "import": "./dist/integration.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "test": "vitest"
  },
  "keywords": [
    "astro",
    "astro-component",
    "reactflow",
    "diagrams",
    "flowchart"
  ],
  "author": "sjohansson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sjohansson/astro-components.git",
    "directory": "packages/astro-reactflow"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@astrojs/react": "^5.0.7",
    "@xyflow/react": "^12.3.5",
    "astro": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "sideEffects": [
    "./dist/**/*.css"
  ],
  "devDependencies": {
    "@astrojs/react": "^5.0.7",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@xyflow/react": "^12.10.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "dependencies": {
    "html-to-image": "^1.11.13"
  }
}
