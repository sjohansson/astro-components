{
  "name": "@sjohansson/astro-components",
  "version": "0.1.0",
  "private": true,
  "description": "A collection of modern Astro components",
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "scripts": {
    "build": "pnpm --filter \"./packages/*\" run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm run build && changeset publish",
    "clean": "pnpm --filter \"./packages/*\" run clean && node -e \"fs.rmSync('node_modules',{recursive:true,force:true})\"",
    "dev": "pnpm --filter \"./packages/*\" --parallel run dev"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.5.1",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "astro": "^7.0.0",
    "happy-dom": "^20.10.6",
    "markdownlint-cli2": "^0.22.1",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "pnpm": {}
}
