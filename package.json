{
  "name": "@sjohansson/astro-components",
  "version": "0.1.0",
  "private": true,
  "description": "A collection of modern Astro components",
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "scripts": {
    "build": "pnpm --filter \"./packages/*\" run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm run build && changeset publish",
    "clean": "pnpm --filter \"./packages/*\" run clean && node -e \"fs.rmSync('node_modules',{recursive:true,force:true})\"",
    "dev": "pnpm --filter \"./packages/*\" --parallel run dev"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.5.1",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "astro": "^7.0.0",
    "happy-dom": "^20.10.6",
    "markdownlint-cli2": "^0.23.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "pnpm": {}
}
