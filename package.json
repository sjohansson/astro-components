{
  "name": "@sjohansson/astro-components",
  "version": "0.1.0",
  "private": true,
  "description": "A collection of modern Astro components",
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.34.1+sha512.b58fbde6dca66a929538021581f648b4570b6ca19b18e7cbd7f2c07a7b24454155388dacdf08f2af3678e88a6d1fe04f9d609df24bf51735a060ea041b374ab7",
  "scripts": {
    "build": "pnpm --filter \"./packages/*\" run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm run build && changeset publish",
    "clean": "pnpm --filter \"./packages/*\" run clean && node -e \"fs.rmSync('node_modules',{recursive:true,force:true})\"",
    "dev": "pnpm --filter \"./packages/*\" --parallel run dev"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.4.16",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "astro": "^6.4.2",
    "happy-dom": "^20.9.0",
    "markdownlint-cli2": "^0.22.1",
    "tsdown": "^0.22.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.7"
  },
  "pnpm": {}
}
