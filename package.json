{
  "name": "@sjohansson/astro-components",
  "version": "0.1.0",
  "private": true,
  "description": "A collection of modern Astro components",
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800",
  "scripts": {
    "build": "pnpm --filter \"./packages/*\" run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm run build && changeset publish",
    "clean": "pnpm --filter \"./packages/*\" run clean && node -e \"fs.rmSync('node_modules',{recursive:true,force:true})\"",
    "dev": "pnpm --filter \"./packages/*\" --parallel run dev"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.4.16",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.6",
    "astro": "^6.3.5",
    "happy-dom": "^20.9.0",
    "markdownlint-cli2": "^0.22.1",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.6"
  },
  "pnpm": {}
}
