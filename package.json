{
  "name": "@sjohansson/astro-components",
  "version": "0.1.0",
  "private": true,
  "description": "A collection of modern Astro components",
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
  "scripts": {
    "build": "pnpm --filter \"./packages/*\" run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm run build && changeset publish",
    "clean": "pnpm --filter \"./packages/*\" run clean && node -e \"fs.rmSync('node_modules',{recursive:true,force:true})\"",
    "dev": "pnpm --filter \"./packages/*\" --parallel run dev"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.5.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.8",
    "astro": "^6.4.6",
    "happy-dom": "^20.10.3",
    "markdownlint-cli2": "^0.22.1",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "pnpm": {}
}
