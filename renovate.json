{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "schedule": ["before 6am on Monday"],
  "timezone": "UTC",
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major"],
      "groupName": "major dependencies"
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "non-major dependencies",
      "labels": ["dependencies", "non-major"]
    },
    {
      "matchPackageNames": ["astro", "@astrojs/*"],
      "groupName": "Astro",
      "labels": ["dependencies", "astro"]
    },
    {
      "matchPackageNames": ["typescript"],
      "groupName": "TypeScript",
      "labels": ["dependencies", "typescript"]
    },
    {
      "matchPackageNames": ["@biomejs/biome"],
      "groupName": "Biome",
      "labels": ["dependencies", "biome"]
    },
    {
      "matchPackageNames": ["vitest", "@vitest/ui", "@vitest/coverage-v8"],
      "groupName": "Vitest",
      "labels": ["dependencies", "vitest"]
    },
    {
      "matchPackageNames": ["react", "react-dom", "@types/react", "@types/react-dom"],
      "groupName": "React",
      "labels": ["dependencies", "react"]
    },
    {
      "matchPackageNames": ["@xyflow/react"],
      "groupName": "React Flow",
      "labels": ["dependencies", "reactflow"]
    },
    {
      "matchPackageNames": ["@changesets/cli"],
      "groupName": "Changesets",
      "labels": ["dependencies", "changesets"]
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on the first day of the month"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
