---
// Pull in the SEPARATE CSS files that drive theming. Order matters:
//   1. tokens.css    — baseline tokens keyed on data-theme-scheme
//   2. advanced.css  — category / family / exact-id overrides (must win)
//   3. base.css      — page + component styling that consumes the tokens
// Astro bundles these into a single global stylesheet in import order.
import "../styles/tokens.css";
import "../styles/advanced.css";
import "../styles/base.css";

interface Props {
  title?: string;
}

const { title = "Theme Showcase — Data Attributes" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title}</title>
    <!--
      The Astro integration injects a tiny inline FOUC script here that replays
      the persisted `data-theme*` attributes onto <html> before first paint.
      See astro.config.mjs (applyMode: "attribute").
    -->
  </head>
  <body>
    <slot />
  </body>
</html>
